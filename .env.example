# Supabase
NEXT_PUBLIC_SUPABASE_URL=
# Client key: legacy anon JWT or new publishable key
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Server key: legacy service_role JWT or new secret key
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=
# Optional — not required by the app today
# SUPABASE_JWKS_URL=

# App
# In production this MUST be the real public HTTPS URL — it's baked into
# every generated Apple pass as `webServiceURL` (Apple's servers call back
# into it) and used to build Google Wallet asset URLs.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: enable Google / Apple in Supabase Auth providers,
# then add the redirect URL: {NEXT_PUBLIC_APP_URL}/auth/callback

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Apple Wallet
# Pass Type ID, e.g. pass.com.stampwallet.loyalty (Certificates, IDs & Profiles)
APPLE_PASS_TYPE_IDENTIFIER=
# Your 10-character Apple Developer Team ID
APPLE_TEAM_IDENTIFIER=
# Base64 of the Pass Type ID .p12 export (Keychain Access: export the cert
# + private key together as .p12, then: base64 -w0 cert.p12  — on macOS use
# `base64 -i cert.p12` instead of -w0)
APPLE_PASS_CERTIFICATE=
# The password you set when exporting the .p12 (empty string is fine if none)
APPLE_PASS_CERTIFICATE_PASSWORD=
# Apple WWDR intermediate certificate (download from Apple PKI, "G4" is
# current as of 2025). Either raw PEM text or base64 of it both work —
# base64 -w0 AppleWWDRCAG4.pem
APPLE_WWDR_CERTIFICATE=

# Google Wallet
# From the Google Wallet Console (Business account → Issuer ID)
GOOGLE_WALLET_ISSUER_ID=
# The full JSON key file for a service account with Wallet Object Issuer
# permission, either pasted raw or base64-encoded (base64 avoids env var
# systems mangling the embedded newlines in private_key):
# base64 -w0 service-account-key.json
GOOGLE_WALLET_SERVICE_ACCOUNT_KEY=
